@model IEnumerable<Frontendtest1703.Models.Prescription>

@{
    ViewData["Title"] = "My Prescriptions";
}

<div class="container mt-4">
    <h2><i class="fas fa-prescription me-2 text-primary"></i>My Prescriptions</h2>

    @if (TempData["AppointmentErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["AppointmentErrorMessage"]</div>
    }

    <div class="card shadow-sm mt-4">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Medicines</th>
                                <th>Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>
                                        <ul class="list-unstyled mb-0">
                                            @foreach (var med in item.Medicines)
                                            {
                                                <li><strong>@med.Name</strong> (@med.Dosage, @med.Duration)</li>
                                            }
                                        </ul>
                                    </td>
                                    <td>@item.Notes</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">No prescriptions found.</p>
            }
        </div>
    </div>
</div>
