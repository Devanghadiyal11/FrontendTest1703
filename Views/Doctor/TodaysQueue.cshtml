@model IEnumerable<Frontendtest1703.Models.QueueEntry>

@{
    ViewData["Title"] = "Doctor's Today's Queue";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-clipboard-list me-2 text-primary"></i>Today's Patient Queue</h2>
    </div>

    @if (TempData["DoctorSuccessMessage"] != null)

    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["DoctorSuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["DoctorErrorMessage"] != null)

    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["DoctorErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="accordion" id="queueAccordion">
                    @foreach (var item in Model)
                    {
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="heading-@item.Id">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                    data-bs-target="#collapse-@item.Id" aria-expanded="false" aria-controls="collapse-@item.Id">
                                    <span class="badge bg-primary me-2">Token: @item.TokenNumber</span>
                                    @item.PatientName
                                    <span
                                        class="ms-auto badge @(item.Status == "waiting" ? "bg-warning text-dark" : item.Status == "in_progress" ? "bg-info text-dark" : item.Status == "done" ? "bg-success" : "bg-danger")">@item.Status</span>
                                </button>
                            </h2>
                            <div id="collapse-@item.Id" class="accordion-collapse collapse" aria-labelledby="heading-@item.Id"
                                data-bs-parent="#queueAccordion">
                                <div class="accordion-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <h6>Add Prescription</h6>
                                            <form asp-controller="Doctor" asp-action="AddPrescription" method="post">
                                                <input type="hidden" name="appointmentId" value="@item.AppointmentId" />
                                                <div class="mb-2">
                                                    <input type="text" name="Medicines[0].Name"
                                                        class="form-control form-control-sm" placeholder="Medicine Name"
                                                        required />
                                                </div>
                                                <div class="mb-2">
                                                    <input type="text" name="Medicines[0].Dosage"
                                                        class="form-control form-control-sm" placeholder="Dosage" required />
                                                </div>
                                                <div class="mb-2">
                                                    <input type="text" name="Medicines[0].Duration"
                                                        class="form-control form-control-sm" placeholder="Duration" required />
                                                </div>
                                                <div class="mb-2">
                                                    <textarea name="notes" class="form-control form-control-sm"
                                                        placeholder="Notes"></textarea>
                                                </div>
                                                <button type="submit" class="btn btn-sm btn-primary">Save Prescription</button>
                                            </form>
                                        </div>
                                        <div class="col-md-6">
                                            <h6>Add Report</h6>
                                            <form asp-controller="Doctor" asp-action="AddReport" method="post">
                                                <input type="hidden" name="appointmentId" value="@item.AppointmentId" />
                                                <div class="mb-2">
                                                    <input type="text" name="diagnosis" class="form-control form-control-sm"
                                                        placeholder="Diagnosis" required />
                                                </div>
                                                <div class="mb-2">
                                                    <input type="text" name="testRecommended" class="form-control form-c
                       o                        ntrol-sm" placeholder="Tests Recommended" required />
                                                </div>
                                                <div class="mb-2">
                                                    <textarea name="remarks" class="form-control form-control-sm"
                                                        placeholder="Remarks" required></textarea>
                                                </div>
                                                <button type="submit" class="btn btn-sm btn-success">Save Report</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">No patients in the queue for today.</div>
            }
        </div>
    </div>
</div>
