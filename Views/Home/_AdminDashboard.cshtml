@model Frontendtest1703.Models.DashboardViewModel

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-users me-2 text-primary"></i>User Management</h5>
                <a asp-controller="Admin" asp-action="Users" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body">
                @if (Model.Users != null && Model.Users.Any())
                {
                    <p class="card-text">Total Users: <strong>@Model.Users.Count</strong></p>
                    <ul class="list-group list-group-flush">
                        @foreach (var user in Model.Users.Take(5))
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @user.Name
                                <span class="badge bg-secondary rounded-pill">@user.Role</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">No users found.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-hospital-user me-2 text-primary"></i>Clinic Information</h5>
                <a asp-controller="Admin" asp-action="ClinicInfo" class="btn btn-sm btn-outline-primary">Edit</a>
            </div>
            <div class="card-body">
                @if (Model.ClinicInfo != null)
                {
                    <h6 class="card-title">@Model.ClinicInfo.Name</h6>
                    <p class="card-text small text-muted">@Model.ClinicInfo.Address</p>
                    <p class="card-text"><strong>Phone:</strong> @Model.ClinicInfo.PhoneNumber</p>
                    <p class="card-text"><strong>Clinic Code:</strong> @Model.ClinicInfo.Code</p>
                }
                else
                {
                    <p class="text-muted">No clinic information available.</p>
                }
            </div>
        </div>
    </div>
</div>
