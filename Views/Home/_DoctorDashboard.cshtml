@model Frontendtest1703.Models.DashboardViewModel

<div class="row">
    <div class="col-12 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-clipboard-list me-2 text-primary"></i>Today's Queue</h5>
                <a asp-controller="Doctor" asp-action="TodaysQueue" class="btn btn-sm btn-outline-primary">Full
                    Queue</a>
            </div>
            <div class="card-body">
                @if (Model.Queue != null && Model.Queue.Any())

                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Token</th>
                                    <th>Patient Name</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Queue.Take(5))

                                {
                                    <tr>
                                        <td><strong>#@item.TokenNumber</strong></td>
                                        <td>@item.PatientName</td>
                                        <td>
                                            <span
                                                class="badge @(item.Status?.ToLower() == "completed" ? "bg-success" : (item.Status?.ToLower() == "in-progress" ? "bg-warning text-dark" : "bg-info text-dark"))">
                                                @item.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                else

                {
                    <p class="text-muted mb-0">No patients in queue for today.</p>
                }
            </div>
        </div>
    </div>
</div>
